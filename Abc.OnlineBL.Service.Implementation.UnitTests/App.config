<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="abcSettings" type="Abc.AIS.Utility.Configuration.AbcConfigSectionHandler,Abc.AIS.Utility"/>
  <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
   <section name="Abc.AIS.Service.Implementation.UnitTests.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </sectionGroup>
 </configSections>

	<abcSettings activeProfile="ABC_BETA" xmlns="http://www.photosigns.com.au/AbcSettings.xsd">
		<!-- SPECIFY ACTIVE  PROFILE NAME HERE (ABC, NZ, ABC_BETA, NZ_BETA) -->
		<!-- COMMON SECTION -->
		<profile name="Common">
			<add key="SMTP_SERVER" value="mail"/>
			<add key="SEND_ERROR_MESSAGE_TO" value="errors@photosigns.com.au"/>
		</profile>
		<!-- END OF COMMON SECTION -->
		<!-- ABC SECTION -->
		<profile name="ABC">
			<add key="SMTP_SERVER" value="mail"/>
			<add key="DB_CONN" value="Data Source=DbServer;Initial Catalog=ABCDB;Integrated Security=True"/>
			<add key="VFS_ROOT_URL" value="http://localhost/Abc.AIS.VirtualFileSystemProvider/"/>
			<add key="AOP_TEMPLATE_ROOT_DIR" value="\\aopserver1\DocumentsRoot"/>
			<add key="GREEN_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\Mercury\xfer\4 Artroom\GREEN"/>
			<add key="GRAY_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="RED_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="GRAPHICS_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="IMAGING_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
		</profile>
		<!-- END OF ABC SECTION -->
		<!-- NZ SECTION -->
		<profile name="NZ">
			<add key="SMTP_SERVER" value="mail"/>
			<add key="DB_CONN" value="Data Source=SQLCLNZ2008\NZ;Initial Catalog=ABCNZ;Integrated Security=True"/>
			<add key="VFS_ROOT_URL" value="http://192.168.1.1:980/Abc.AIS.VirtualFileSystemProvider/"/>
			<add key="AOP_TEMPLATE_ROOT_DIR" value="\\192.168.1.4\DocumentsRootNZ"/>
			<add key="GREEN_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="GRAY_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="RED_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="GRAPHICS_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
			<add key="IMAGING_PROPERTY_PHOTO_OUTPUT_FOLDER" value=""/>
		</profile>
		<!-- END OF NZ SECTION -->
		<!-- BETA FOR ABC SECTION -->
		<profile name="ABC_BETA">
			<add key="SMTP_SERVER" value="mail"/>
			<add key="DB_CONN" value="Data Source=DbServer;Initial Catalog=ABC_BETA;Integrated Security=True"/>
			<add key="VFS_ROOT_URL" value="http://localhost/Abc.AIS.VirtualFileSystemProvider/"/>
			<add key="AOP_TEMPLATE_ROOT_DIR" value="\\FileGateway\Xfer\4 Ha\AbcOnlinePublication\DocumentsRoot"/>
			<add key="IS_NZ" value="false"/>
			<add key="GREEN_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\filegateway\xfer\4 Kenny\Uploaded Images\Green"/>
			<add key="GRAY_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\filegateway\xfer\4 Kenny\Uploaded Images\Gray"/>
			<add key="RED_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\filegateway\xfer\4 Kenny\Uploaded Images\Red"/>
			<add key="GRAPHICS_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\filegateway\xfer\4 Kenny\Uploaded Images\Graphics"/>
			<add key="IMAGING_PROPERTY_PHOTO_OUTPUT_FOLDER" value="\\filegateway\xfer\4 Kenny\Uploaded Images\Imaging"/>
		</profile>
		<!-- END OF BETA FOR ABC SECTION -->
	</abcSettings>

	<system.serviceModel>
		<bindings>
			<wsHttpBinding>
				<binding name="VFSHttpBindingConfig" maxBufferPoolSize="5242880" maxReceivedMessageSize="6553600">
					<readerQuotas maxDepth="32" maxStringContentLength="307200" maxArrayLength="163840"
      maxBytesPerRead="4096" maxNameTableCharCount="16384" />
					<reliableSession ordered="true" inactivityTimeout="00:20:00" enabled="false" />
					<security mode="Message">
						<transport clientCredentialType="Windows" proxyCredentialType="None"
       realm="" />

						<message clientCredentialType="Windows" negotiateServiceCredential="true"
       algorithmSuite="Default" establishSecurityContext="true" />
					</security>
				</binding>
			</wsHttpBinding>
		</bindings>
		<client>
			<endpoint address="http://localhost/Abc.AIS.VirtualFileSystemProvider/File.svc"
    binding="wsHttpBinding" bindingConfiguration="VFSHttpBindingConfig"
    contract="Abc.AIS.VirtualFileSystem.IFile" name="IFile">
			</endpoint>
			<endpoint address="http://localhost/Abc.AIS.VirtualFileSystemProvider/Directory.svc"
    binding="wsHttpBinding" bindingConfiguration="VFSHttpBindingConfig"
    contract="Abc.AIS.VirtualFileSystem.IDirectory" name="IDirectory">
			</endpoint>
		</client>
	</system.serviceModel>
 <applicationSettings>
  <Abc.AIS.Service.Implementation.UnitTests.Properties.Settings>
   <setting name="TEMPORARY_PHOTO_OUTPUT_FOLDER" serializeAs="String">
    <value>\\FileGateway\xfer\4 Kenny\Uploaded Images\TempImages</value>
   </setting>
  </Abc.AIS.Service.Implementation.UnitTests.Properties.Settings>
 </applicationSettings>
</configuration>