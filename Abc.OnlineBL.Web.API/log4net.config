<?xml version="1.0" encoding="utf-8" ?>
<!-- This section contains the log4net configuration settings -->
<log4net>
  <!-- Define some output appenders -->
  <appender name="SmtpAppender" type="Abc.OnlineBL.Utility.AbcSmtpAppender,Abc.OnlineBL.Utility">
    <to value="webdesign@photosigns.com.au" />
    <from value="errors@photosigns.com.au" />
    <subject value="[Log::Abc OnlineBL Service]" />
    <smtpHost value="mail.photosigns.com.au" />
    <bufferSize value="512" />
    <lossy value="true" />
    <evaluator type="log4net.Core.LevelEvaluator,log4net">
      <threshold value="DEBUG"/>
    </evaluator>
    <!-- The filters are processed in order: 
          1) match any WARN or higher messages
          2) reject everything else -->
    <filter type="log4net.Filter.LevelRangeFilter">
      <levelMin value="WARN" />
      <acceptOnMatch value="true" />
    </filter>
    <filter type="log4net.Filter.DenyAllFilter" />
    <layout type="log4net.Layout.PatternLayout,log4net">
      <header value="Abc OnlineBL Service Log&#xD;&#xA;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~&#xD;&#xA;" />
      <footer value="&#xD;&#xA;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~&#xD;&#xA;" />
      <conversionPattern value="%property{log4net:HostName} :: %level :: %message %newlineLogger: %logger%newlineThread: %thread%newlineDate: %date%newlineNDC: %property{NDC}%newline%newline" />
    </layout>
  </appender>
  <appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender">
    <file value="Logs\OnlineBLLog.txt" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <appendToFile value="true" />
    <rollingStyle value="Date" />
    <datePattern value="yyyyMMdd" />
    <layout type="log4net.Layout.PatternLayout">
      <header value="Abc OnlineBL Service Log&#xD;&#xA;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~&#xD;&#xA;" />
      <footer value="&#xD;&#xA;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~&#xD;&#xA;" />
      <conversionPattern value="%date [%3thread] %-5level - %message%newline" />
    </layout>
  </appender>
  <!-- Setup the root category, add the appenders and set the default level -->
  <root>
    <level value="DEBUG" />
    <appender-ref ref="RollingLogFileAppender" />
    <appender-ref ref="SmtpAppender" />
  </root>
</log4net>
